# --- Secrets / credentials ---
# clasp: 프로젝트 ID는 .clasp.json(커밋). OAuth 토큰은 홈의 ~/.clasprc.json(비커밋)
.env
.env.*
credentials.json
.clasprc.json
*.key
*.pem
*.p12

# --- 프론트: 런타임(JS/CSS)은 eunsang9597/solpath-dashboard-front. 모노레포에는 jsDelivr 핀·스니펫만 추적
front/*
!front/SOLPATH_CDN_COMMIT
!front/IMWEB_SNIPPET_INJECT.html
!front/IMWEB_SNIPPET.html
# 배포용 일회 클론(solpath-dashboard-front)
.tmp-solpath-dashboard-front/

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Logs ---
*.log
npm-debug.log*
