# --- Secrets / credentials ---
# clasp: 프로젝트 ID는 .clasp.json(커밋). OAuth 토큰은 홈의 ~/.clasprc.json(비커밋)
.env
.env.*
credentials.json
.clasprc.json
*.key
*.pem
*.p12

# --- 프론트: 별도 GitHub 레포(front/ 안에서 git init). 중첩 .git vs 메타 레포 충돌 방지 ---
/front/

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- Logs ---
*.log
npm-debug.log*
